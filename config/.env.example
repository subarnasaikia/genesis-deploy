# ============================================================================
# genesis-deploy — environment configuration
#
# Copy this file to the repo root as `.env` and fill in every REQUIRED value:
#   cp config/.env.example .env
#
# This single file drives the whole stack: docker compose interpolates it and
# forwards the relevant variables to each container.
# Never commit the filled-in `.env`.
# ============================================================================

# ----------------------------------------------------------------------------
# Source repositories — REQUIRED
# The pipeline clones these at $DEPLOY_BRANCH into ./sources/.
# Use HTTPS URLs (with a token if private) or SSH URLs if the host has keys.
# ----------------------------------------------------------------------------
BACKEND_REPO_URL=https://github.com/OWNER/genesis.git
FRONTEND_REPO_URL=https://github.com/OWNER/genesis-frontend.git
DEPLOY_BRANCH=uni-prod

# ----------------------------------------------------------------------------
# Database — REQUIRED
# Postgres runs as a compose service; it is NOT exposed on the host network.
# The backend reaches it at postgres:5432 inside the compose network.
# ----------------------------------------------------------------------------
POSTGRES_DB=genesis
POSTGRES_USER=postgres
# Use a strong value. Compose refuses to start if unset.
POSTGRES_PASSWORD=change-me-strong-password

# ----------------------------------------------------------------------------
# Backend — Spring Boot
# ----------------------------------------------------------------------------
# REQUIRED. Must be at least 256 bits (32 ASCII chars) for HS256.
# The backend fails fast at boot if unset, blank, or <32 chars.
# Generate with: openssl rand -base64 48 | tr -d '\n='
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48

# Optional token expiries (Spring Duration strings). Defaults: 15m / 7d.
# JWT_ACCESS_TOKEN_EXPIRY=15m
# JWT_REFRESH_TOKEN_EXPIRY=7d

# ----------------------------------------------------------------------------
# File storage
# STORAGE_PROVIDER selects where raw uploads live:
#   cloudinary (default) -> external Cloudinary; set CLOUDINARY_* below
#   local                -> on-disk under STORAGE_LOCAL_BASE_PATH; no Cloudinary needed
# STORAGE_RETAIN_SOURCE: true (default) keeps the raw upload after tokenization;
#   false deletes it once tokenized (re-tokenize from the original then unavailable).
# STORAGE_LOCAL_BASE_PATH: container path for the local provider, persisted via a
#   volume in docker/docker-compose.yml. Default /app/data/uploads.
# ----------------------------------------------------------------------------
STORAGE_PROVIDER=cloudinary
STORAGE_RETAIN_SOURCE=true
# STORAGE_LOCAL_BASE_PATH=/app/data/uploads

# Cloudinary file-storage credentials (https://cloudinary.com).
# REQUIRED when STORAGE_PROVIDER=cloudinary (the default); leave blank for local.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# REQUIRED in prod. Comma-separated list of frontend origins allowed to call
# the API. Must match the URL users type into their browser.
# Example: http://genesis.example.edu:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Frontend — Next.js
# ----------------------------------------------------------------------------
# REQUIRED. The backend's URL as seen FROM THE BROWSER (not from inside
# Docker). Baked into the frontend bundle at build time — changing it
# requires rebuilding the frontend image.
# Example: http://genesis.example.edu:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Ports published on the host (change if they clash with other services)
# ----------------------------------------------------------------------------
BACKEND_PORT=8080
FRONTEND_PORT=3000
